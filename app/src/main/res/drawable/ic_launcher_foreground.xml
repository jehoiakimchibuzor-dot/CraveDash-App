<?xml version="1.0" encoding="utf-8"?>
<!--
    CraveDash launcher icon — "CD⚡" premium brand mark
    Viewport 108×108  |  Safe zone 72×72 centred at (18,18)

    Design language:
      • Bold white "C" letter (left) — "Crave"
      • Bold white "D" letter (right) — "Dash"
      • Orange lightning bolt inside the C's right opening — the "Dash" energy mark
      • The bolt fills the natural negative space of the C letter
      • Three elements read as ONE unified monogram

    At any size: the silhouette reads as an energetic CD mark with a bolt.
    Premium, brand-specific, memorable at 48px.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Letter C ──────────────────────────────────────────────────────── -->
    <!--
        Bold C — thick ring arc open on the right.
        Outer boundary: large arc from top-right, sweeping left, to bottom-right.
        Inner boundary: smaller arc creating the letter thickness.
        Opening gap (right side): y ≈ 30 to y ≈ 78 — this is where the bolt lives.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
        M 60,20
        Q 42,12 28,24
        Q 14,36 14,54
        Q 14,72 28,84
        Q 42,96 60,88
        L 60,78
        Q 46,84 36,74
        Q 24,64 24,54
        Q 24,44 36,34
        Q 46,24 60,30
        Z
        "/>

    <!-- ── Letter D ──────────────────────────────────────────────────────── -->
    <!--
        Bold D — vertical left edge, curved right side.
        Uses evenOdd fill so the inner subpath carves out the interior hollow.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
        M 64,20
        L 73,20
        Q 96,20 96,54
        Q 96,88 73,88
        L 64,88
        Z
        M 73,32
        Q 84,32 84,54
        Q 84,76 73,76
        L 73,32
        Z
        "/>

    <!-- ── Lightning bolt — the "Dash" ───────────────────────────────────── -->
    <!--
        Positioned inside the C's right opening.
        Orange (#E07000 = deep warm orange, darker than background so it reads
        as "cut from" the white C while still contrasting on the orange BG).
        Classic zigzag bolt shape — wide top, narrow waist, wide base.
    -->
    <path
        android:fillColor="#CC5500"
        android:pathData="
        M 64,32
        L 56,54
        L 62,54
        L 54,76
        L 72,52
        L 66,52
        Z
        "/>

</vector>
