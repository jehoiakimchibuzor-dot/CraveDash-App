<?xml version="1.0" encoding="utf-8"?>
<!--
    CraveDash onboarding badge — Live GPS Tracking
    Style: premium minimal icon
    A location pin with two concentric pulse rings at the base
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Pin body — classic teardrop shape -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
        M12,2
        C8.13,2 5,5.13 5,9
        C5,14.25 12,22 12,22
        C12,22 19,14.25 19,9
        C19,5.13 15.87,2 12,2 Z"/>

    <!-- Inner hollow circle (negative space inside pin) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#00000000"
        android:pathData="
        M12,6.5
        A2.5,2.5 0 1,0 12.001,6.5 Z"/>

    <!-- Pulse ring 1 (inner) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M8,21 Q12,19.5 16,21"/>

    <!-- Pulse ring 2 (outer) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M5.5,22.5 Q12,20.5 18.5,22.5"/>

</vector>
