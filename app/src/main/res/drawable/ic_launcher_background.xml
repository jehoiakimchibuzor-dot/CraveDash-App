<?xml version="1.0" encoding="utf-8"?>
<!--
    CraveDash launcher background — rich radial orange
    Three concentric layers create a premium depth/glow effect
    without needing aapt:attr gradient syntax.
    Dark at edges, bright warm centre — the C and D appear to glow.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Layer 1: deep rich base orange (edge colour) -->
    <path
        android:fillColor="#D06000"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"/>

    <!-- Layer 2: main brand orange (mid radial) -->
    <path
        android:fillColor="#FF8C00"
        android:pathData="M54,4 A50,50 0 1 1 53.9,4 Z"/>

    <!-- Layer 3: warm bright inner glow -->
    <path
        android:fillColor="#FFB040"
        android:pathData="M54,22 A32,32 0 1 1 53.9,22 Z"/>

</vector>
